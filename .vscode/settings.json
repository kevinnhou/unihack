{
  "files.exclude": {
    "**/.claude": true,
    "**/.codex": true,
    "**/.cursor": true,

    "**/node_modules": false,
    "**/.next": true,
    "**/.turbo": true,
    "**/next-env.d.ts": true,
    "**/next.config.*": true,
    "**/postcss.config.*": true,
    "**/tsconfig.json": true,

    "**/AllianceNo2-Regular.woff2": true,
    "**/apple-icon.png": true,
    "**/favicon.ico": true,
    "**/manifest.ts": true,
    "**/robots.ts": true,
    "**/sitemap.xml": true,

    "**/.ruler": true,
    "**/.source": true,
    "**/source.config.ts": true,

    "**/.expo": true,
    "**/assets": true,
    "**/app.json": true,
    "**/expo-env.d.ts": true,
    "**/global.css": true,
    "**/metro.config.js": true,
    "**/uniwind-types.d.ts": true,

    "**/bunfig.toml": true,
    "**/bun.lock": true,

    "**/.mcp.json": true,
    "**/AGENTS.*": true,
    "**/CLAUDE.*": true
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[graphql]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "emmet.showExpandedAbbreviation": "never",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  }
}