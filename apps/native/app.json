{
  "expo": {
    "scheme": "agon",
    "userInterfaceStyle": "dark",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "agon",
    "slug": "agon",
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Agon needs your location to track your run.",
          "locationAlwaysAndWhenInUsePermission": "Agon needs your location to track your run.",
          "isIosBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "package": "com.agon.app"
    },
    "ios": {
      "bundleIdentifier": "com.agon.app"
    }
  }
}
